    def actualizar_comboboxes(self):
        """Mantiene sincronizadas las listas desplegables evitando errores de captura a ciegas."""
        lista_completa = [f"{p.id} - {p.nombre} ({p.tipo})" for p in self.sistema.productos.values()]
        lista_insumos = [f"{p.id} - {p.nombre}" for p in self.sistema.productos.values() if p.tipo == "insumo"]
        lista_fabricados = [f"{p.id} - {p.nombre}" for p in self.sistema.productos.values() if p.tipo == "fabricado"]

        self.cmb_compras_prod["values"] = lista_completa
        self.cmb_ventas_prod["values"] = lista_completa
        self.cmb_est_prod["values"] = lista_completa
        self.cmb_rec_padre["values"] = lista_fabricados
        self.cmb_rec_insumo["values"] = lista_insumos

    def refrescar_monitor_almacen(self):
        self.txt_monitor.delete("1.0", tk.END)
        self.txt_monitor.insert(tk.END, f"{'ID':<6} | {'PRODUCTO':<25} | {'TIPO':<15} | {'STOCK ACTUAL':<15} | {'COSTO LIFO':<12} | {'ESTADO':<20}\n")
        self.txt_monitor.insert(tk.END, "-" * 100 + "\n")
        
        for p in self.sistema.productos.values():
            costo = p.calcular_costo_fabricacion(self.sistema) if p.tipo == "fabricado" else p.obtener_costo_unitario_lifo()
            estado = p.evaluar_estado_stock()
            st_str = f"{p.stock_actual:.1f} {p.unidad}"
            self.txt_monitor.insert(tk.END, f"{p.id:<6} | {p.nombre:<25} | {p.tipo:<15} | {st_str:<15} | ${costo:<11.2f} | {estado:<20}\n")

    def ui_registrar_producto(self):
        try:
            id_p = int(self.ent_id.get())
            nombre = self.ent_nombre.get().strip()
            tipo = self.cmb_tipo.get()
            unidad = self.cmb_unidad.get()
            s_min = float(self.ent_min.get())
            s_max = float(self.ent_max.get())

            if not nombre:
                messagebox.showerror("Error", "Debe asignar un nombre válido.")
                return

            if id_p in self.sistema.productos:
                messagebox.showerror("Error", "Este ID de artículo ya existe en el catálogo corporativo.")
                return

            nuevo = Producto(id_p, nombre, tipo, unidad, s_min, s_max)
            self.sistema.productos[id_p] = nuevo
            self.sistema.guardar_datos()
            messagebox.showinfo("Éxito", f"Producto '{nombre}' indexado con éxito.")
            
            self.actualizar_comboboxes()
            self.refrescar_monitor_almacen()
        except ValueError:
            messagebox.showerror("Error", "Los campos ID, Stock Mínimo y Máximo deben ser numéricos.")

    def ui_ligar_receta(self):
        try:
            if not self.cmb_rec_padre.get() or not self.cmb_rec_insumo.get():
                messagebox.showerror("Error", "Seleccione ambos productos de las listas desplegables.")
                return
            
            id_padre = int(self.cmb_rec_padre.get().split(" - ")[0])
            id_insumo = int(self.cmb_rec_insumo.get().split(" - ")[0])
            cantidad = float(self.ent_rec_cant.get())

            prod_padre = self.sistema.productos[id_padre]
            prod_padre.receta[id_insumo] = cantidad
            self.sistema.guardar_datos()
            
            messagebox.showinfo("Receta Enlazada", f"Ligados {cantidad} del insumo al producto final con éxito.")
            self.refrescar_monitor_almacen()
        except ValueError:
            messagebox.showerror("Error", "La cantidad requerida debe ser un dato numérico.")

    def ui_agregar_costo_fijo(self):
        try:
            desc = self.ent_cf_desc.get().strip()
            temp = self.cmb_cf_temp.get()
            monto = float(self.ent_cf_monto.get())

            if not desc:
                messagebox.showerror("Error", "Falta la descripción del costo fijo.")
                return

            nuevo_cf = CostoFijo(desc, temp, monto)
            self.sistema.costos_fijos.append(nuevo_cf)
            self.sistema.guardar_datos()
            messagebox.showinfo("Costo Guardado", f"Costo fijo '{desc}' registrado en el presupuesto.")
        except ValueError:
            messagebox.showerror("Error", "El monto del costo fijo debe ser numérico.")

    def ui_procesar_abastecimiento(self):
        try:
            if not self.cmb_compras_prod.get():
                messagebox.showerror("Error", "Seleccione un producto existente de la lista.")
                return

            id_p = int(self.cmb_compras_prod.get().split(" - ")[0])
            cantidad = float(self.ent_comp_cant.get())
            subtotal = float(self.ent_comp_sub.get())
            logistica = float(self.ent_comp_log.get())
            modalidad = self.cmb_modalidad.get()

            # Lógica exacta del Flujo: Costo real LIFO incluye Logística
            costo_total_adquisicion = subtotal + logistica
            costo_unitario_neto = costo_total_adquisicion / cantidad

            producto = self.sistema.productos[id_p]
            producto.registrar_compra_lifo(cantidad, costo_unitario_neto)
            
            estado_almacen = producto.evaluar_estado_stock()
            self.sistema.guardar_datos()
            
            msg = f"Surtido LIFO completado.\nCosto Unitario Calculado: ${costo_unitario_neto:.2f}\nEstado: {estado_almacen}"
            messagebox.showinfo("Almacén Actualizado", msg)
            self.refrescar_monitor_almacen()
        except ValueError:
            messagebox.showerror("Error", "Valide que cantidad, subtotal y fletes sean numéricos.")

    def ui_procesar_venta(self):
        try:
            if not self.cmb_ventas_prod.get():
                messagebox.showerror("Error", "Seleccione el producto de la lista.")
                return

            id_p = int(self.cmb_ventas_prod.get().split(" - ")[0])
            cantidad = float(self.ent_vent_cant.get())
            precio = float(self.ent_vent_precio.get())

            producto = self.sistema.productos[id_p]

            # Si es un artículo fabricado, validar primero la disponibilidad de sus recetas
            if producto.tipo == "fabricado":
                for id_insumo, cant_necesaria in producto.receta.items():
                    insumo = self.sistema.productos.get(id_insumo)
                    if not insumo or insumo.stock_actual < (cant_necesaria * cantidad):
                        messagebox.showerror("Falta de Insumos", f"Operación Rebotada. Stock insuficiente del insumo: '{insumo.nombre if insumo else id_insumo}'")
                        return
                
                # Descontar insumos proporcionalmente
                for id_insumo, cant_necesaria in producto.receta.items():
                    self.sistema.productos[id_insumo].stock_actual -= (cant_necesaria * cantidad)
                
                producto.stock_actual += cantidad  # Simulación de ensamble inmediato

            if producto.stock_actual < cantidad:
                messagebox.showerror("Stock Insuficiente", f"No hay suficientes unidades físicas de '{producto.nombre}' en el inventario.")
                return

            # Registrar Salida
            producto.stock_actual -= cantidad
            producto.historial_ventas.append({
                "fecha": datetime.now().strftime("%Y-%m-%d"),
                "cantidad": cantidad,
                "precio": precio
            })
            self.sistema.guardar_datos()
            messagebox.showinfo("Venta Éxitosa", f"Venta procesada. Quedan {producto.stock_actual} {producto.unidad} en almacén.")
            self.refrescar_monitor_almacen()
        except ValueError:
            messagebox.showerror("Error", "Valide los campos numéricos en la venta.")

    def ui_registrar_competencia(self):
        if not self.cmb_est_prod.get():
            messagebox.showerror("Error", "Seleccione un producto para benchmarking.")
            return
        try:
            id_p = int(self.cmb_est_prod.get().split(" - ")[0])
            nombre_c = self.ent_comp_name.get().strip()
            precio_c = float(self.ent_comp_pmercad.get())

            if not nombre_c:
                messagebox.showerror("Error", "Indique el nombre del competidor.")
                return

            self.sistema.productos[id_p].competidores.append({"competidor": nombre_c, "precio": precio_c})
            self.sistema.guardar_datos()
            messagebox.showinfo("Benchmarking", f"Precio de competencia guardado para '{self.sistema.productos[id_p].nombre}'.")
        except ValueError:
            messagebox.showerror("Error", "El precio de mercado debe ser un número.")

    def ui_calcular_estrategia_completa(self):
        if not self.cmb_est_prod.get():
            messagebox.showerror("Error", "Seleccione un producto para correr los modelos.")
            return
        
        id_p = int(self.cmb_est_prod.get().split(" - ")[0])
        producto = self.sistema.productos[id_p]

        try:
            m_base = float(self.ent_m_base.get())
            m_promo = float(self.ent_m_promo.get())
        except ValueError:
            messagebox.showerror("Error", "Los márgenes deben expresarse en decimales (ej: 0.60).")
            return

        # 1. Obtener Costo Base (LIFO o Receta)
        costo_base = producto.calcular_costo_fabricacion(self.sistema) if producto.tipo == "fabricado" else producto.obtener_costo_unitario_lifo()
        
        if costo_base == 0:
            messagebox.showerror("Inconsistencia Financiera", "No se puede calcular estrategias porque el producto no tiene un historial de costos real registrado.")
            return

        # 2. Modelación de Precios de tu Flujo (Margen 1, Margen 2, Margen 3)
        precio_deseado = costo_base / (1 - m_base)
        precio_estrategico = costo_base / (1 - m_promo)
        
        precios_mercado = [c["precio"] for c in producto.competidores]
        precio_competitivo = sum(precios_mercado) / len(precios_mercado) if precios_mercado else precio_deseado

        # 3. Sumar Costos Fijos Mensualizados globales
        carga_fija_mensual = sum(cf.obtener_mensualizado() for cf in self.sistema.costos_fijos)

        # 4. Simulación del Punto de Equilibrio de este producto específico
        # Unidades necesarias = Costos Fijos / Margen de contribución en Pesos (usando el Precio Deseado)
        margen_contribucion_pesos = precio_deseado - costo_base
        punto_equilibrio_unidades = carga_fija_mensual / margen_contribucion_pesos if margen_contribucion_pesos > 0 else 0

        # 5. Evaluación de la Salud Financiera del Operador (Ventas reales acumuladas)
        total_ingresos_reales = sum(v["cantidad"] * v["precio"] for v in producto.historial_ventas)
        total_unidades_vendidas = sum(v["cantidad"] for v in producto.historial_ventas)
        costo_variable_total = total_unidades_vendidas * costo_base
        utilidad_bruta_real = total_ingresos_reales - costo_variable_total

        # Diagnóstico de salud según tus etiquetas exactas
        if total_ingresos_reales == 0:
            salud_financiera = "⚪ Alerta: Sin historial de ventas capturado en este ciclo operativo."
        elif utilidad_bruta_real > carga_fija_mensual:
            salud_financiera = "🟢 ESTADO: ¡Se están generando ganancias de capital corporativo!"
        elif abs(utilidad_bruta_real - carga_fija_mensual) < (carga_fija_mensual * 0.15) or (total_unidades_vendidas >= punto_equilibrio_unidades * 0.9):
            salud_financiera = "🟡 ESTADO: Se cubren únicamente las operaciones básicas (Zona de Equilibrio)."
        else:
            salud_financiera = "🔴 ALERTA OPERATIVA: Operando debajo de las capacidades financieras mínimas del negocio."

        # Desplegar en el Reporte Corporativo
        self.txt_reporte.delete("1.0", tk.END)
        self.txt_reporte.insert(tk.END, f"========================================================================\n")
        self.txt_reporte.insert(tk.END, f"           📋 INFORME FINANCIERO ESTRATÉGICO: {producto.nombre.upper()}\n")
        self.txt_reporte.insert(tk.END, f"========================================================================\n\n")
        self.txt_reporte.insert(tk.END, f"• Costo Base Unitario LIFO / Estructura Insumos: ${costo_base:.2f}\n")
        self.txt_reporte.insert(tk.END, f"• Costos Fijos Totales de la Empresa (Mensualizados): ${carga_fija_mensual:.2f}\n\n")
        
        self.txt_reporte.insert(tk.END, f"📈 MODELACIÓN DE CANDADOS DE PRECIOS SUGERIDOS:\n")
        self.txt_reporte.insert(tk.END, f"  └─► [PRECIO DESEADO]      (Margen Ganancia Base {m_base*100}%): ${precio_deseado:.2f}\n")
        self.txt_reporte.insert(tk.END, f"  └─► [PRECIO COMPETITIVO]  (Promedio Benchmarking Mercado): ${precio_competitivo:.2f}\n")
        self.txt_reporte.insert(tk.END, f"  └─► [PRECIO ESTRATÉGICO]  (Margen Promocional Piso {m_promo*100}%): ${precio_estrategico:.2f}\n\n")
        
        self.txt_reporte.insert(tk.END, f"🎯 ANÁLISIS DE UMBRAL OPERATIVO:\n")
        self.txt_reporte.insert(tk.END, f"  └─► PUNTO DE EQUILIBRIO: Se deben vender {punto_equilibrio_unidades:.1f} unidades mensuales para amortizar la operación.\n")
        self.txt_reporte.insert(tk.END, f"  └─► Unidades Reales Vendidas en este Ciclo: {total_unidades_vendidas:.1f} pzas.\n\n")
        
        self.txt_reporte.insert(tk.END, f"------------------------------------------------------------------------\n")
        self.txt_reporte.insert(tk.END, f" STATUS DE VIABILIDAD ECONÓMICA:\n {salud_financiera}\n")
        self.txt_reporte.insert(tk.END, f"------------------------------------------------------------------------\n")


