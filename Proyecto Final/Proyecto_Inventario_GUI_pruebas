# 1. MODELOS DE DATOS (NÚCLEO ESTRATÉGICO Y ADMINISTRATIVO)
# =====================================================================

class CostoFijo:
    def __init__(self, descripcion, temporalidad, cantidad):
        self.descripcion = descripcion
        self.temporalidad = temporalidad  # "Mensual" o "Anual"
        self.cantidad = cantidad

    def obtener_mensualizado(self):
        return self.cantidad if self.temporalidad == "Mensual" else self.cantidad / 12.0


class Producto:
    def __init__(self, id_p, nombre, tipo, unidad, stock_minimo=10, stock_maximo=100):
        self.id = id_p
        self.nombre = nombre
        self.tipo = tipo  # "insumo", "comercializado", "fabricado"
        self.unidad = unidad  # "pza", "grs", "ml"
        self.stock_actual = 0.0
        self.stock_minimo = stock_minimo
        self.stock_maximo = stock_maximo
        
        # Estructuras de persistencia basadas en el flujo
        self.receta = {}  # {id_insumo: cantidad_necesaria}
        self.historial_compras = []  # Pila LIFO de lotes
        self.historial_ventas = []  # [{fecha, cantidad, precio}]
        self.competidores = []  # [{nombre, precio}]

    def registrar_compra_lifo(self, cantidad, costo_unitario):
        lote = {"cantidad": cantidad, "costo_unitario": costo_unitario, "fecha": datetime.now().strftime("%Y-%m-%d")}
        self.historial_compras.append(lote)
        self.stock_actual += cantidad

    def obtener_costo_unitario_lifo(self):
        if not self.historial_compras:
            return 0.0
        # Inspeccionar el último lote sin destruirlo (LIFO)
        return self.historial_compras[-1]["costo_unitario"]

    def calcular_costo_fabricacion(self, inventario_global):
        if self.tipo != "fabricado":
            return self.obtener_costo_unitario_lifo()
        
        costo_receta = 0.0
        for id_insumo, cant_necesaria in self.receta.items():
            insumo = inventario_global.productos.get(id_insumo)
            if insumo:
                costo_receta += insumo.obtener_costo_unitario_lifo() * cant_necesaria
        return costo_receta

    def evaluar_estado_stock(self):
        if self.stock_actual <= self.stock_minimo:
            return "⚠️ Alerta de Reestock"
        elif self.stock_actual >= self.stock_maximo:
            return "📦 Alerta de Sobrestock"
        return "✅ Stock en orden"

    def to_dict(self):
        return {
            "id": self.id, "nombre": self.nombre, "tipo": self.tipo, "unidad": self.unidad,
            "stock_actual": self.stock_actual, "stock_minimo": self.stock_minimo, "stock_maximo": self.stock_maximo,
            "receta": {str(k): v for k, v in self.receta.items()}, "historial_compras": self.historial_compras,
            "historial_ventas": self.historial_ventas, "competidores": self.competidores
        }

    @staticmethod
    def from_dict(d):
        p = Producto(d["id"], d["nombre"], d["tipo"], d["unidad"], d["stock_minimo"], d["stock_maximo"])
        p.stock_actual = d["stock_actual"]
        p.receta = {int(k): v for k, v in d["receta"].items()}
        p.historial_compras = d["historial_compras"]
        p.historial_ventas = d["historial_ventas"]
        p.competidores = d["competidores"]
        return p


class SistemaEmpresarial:
    def __init__(self, archivo="erp_data.json"):
        self.archivo = archivo
        self.productos = {}
        self.costos_fijos = []
        self.cargar_datos()

    def guardar_datos(self):
        try:
            data = {
                "productos": {str(id_p): p.to_dict() for id_p, p in self.productos.items()},
                "costos_fijos": [{"descripcion": cf.descripcion, "temporalidad": cf.temporalidad, "cantidad": cf.cantidad} for cf in self.costos_fijos]
            }
            with open(self.archivo, "w", encoding="utf-8") as f:
                json.dump(data, f, indent=4, ensure_ascii=False)
        except Exception as e:
            print(f"Error al guardar persistencia: {e}")

    def cargar_datos(self):
        if os.path.exists(self.archivo) and os.path.getsize(self.archivo) > 0:
            try:
                with open(self.archivo, "r", encoding="utf-8") as f:
                    data = json.load(f)
                    self.productos = {int(id_p): Producto.from_dict(p_dict) for id_p, p_dict in data.get("productos", {}).items()}
                    self.costos_fijos = [CostoFijo(cf["descripcion"], cf["temporalidad"], cf["cantidad"]) for cf in data.get("costos_fijos", [])]
            except Exception as e:
                print(f"Error al cargar datos: {e}")
                self.productos = {}
                self.costos_fijos = []


